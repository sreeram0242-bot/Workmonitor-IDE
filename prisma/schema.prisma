generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
}

enum AppRole {
  admin
  user
}

enum TaskPriority {
  low
  medium
  high
}

enum TaskStatus {
  pending
  completed
  approved
  revision
}

model Profile {
  id               String   @id
  full_name        String
  position         String
  avatar_url       String?
  badge            String?
  created_at       DateTime @default(now())
  notify_messages  Boolean  @default(true)
  notify_tasks     Boolean  @default(true)
  passcode_hash    String?
  pin_attempts     Int      @default(0)
  pin_locked_until DateTime?
  presence_hidden  Boolean  @default(false)
}

model UserRole {
  id      String   @id @default(uuid())
  user_id String
  role    AppRole
}

model Conversation {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())
  created_by String
  is_group   Boolean  @default(false)
  name       String?

  members  ConversationMember[]
  messages Message[]
}

model ConversationMember {
  conversation_id String
  user_id         String
  is_group_admin  Boolean   @default(false)
  joined_at       DateTime  @default(now())
  last_read_at    DateTime  @default(now())
  left_at         DateTime?
  muted_at        DateTime?

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@id([conversation_id, user_id])
}

model Message {
  id              String   @id @default(uuid())
  conversation_id String
  sender_id       String
  content         String
  attachments     Json?
  created_at      DateTime @default(now())
  edited_at       DateTime?
  deleted_at      DateTime?
  deleted_for     String[]
  forwarded_from  String?
  mentions        String[]
  pinned_at       DateTime?
  pinned_by       String?
  reply_to        String?

  conversation Conversation       @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  reactions    MessageReaction[]
  stars        StarredMessage[]
}

model MessageReaction {
  id         String   @id @default(uuid())
  message_id String
  user_id    String
  emoji      String
  created_at DateTime @default(now())

  message Message @relation(fields: [message_id], references: [id], onDelete: Cascade)
}

model StarredMessage {
  message_id String
  user_id    String
  created_at DateTime @default(now())

  message Message @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@id([message_id, user_id])
}

model Task {
  id            String       @id @default(uuid())
  title         String
  description   String?
  assigned_by   String
  assigned_to   String
  priority      TaskPriority
  status        TaskStatus   @default(pending)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
  deadline      DateTime?
  deadline_at   DateTime?
  recurrence    String?
  revision_note String?
  tags          String[]

  comments TaskComment[]
  proofs   TaskProof[]
  subtasks Subtask[]
}

model TaskComment {
  id         String   @id @default(uuid())
  task_id    String
  author_id  String
  body       String
  created_at DateTime @default(now())

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model TaskProof {
  id          String   @id @default(uuid())
  task_id     String
  uploaded_by String
  image_url   String
  note        String?
  created_at  DateTime @default(now())

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model Subtask {
  id         String   @id @default(uuid())
  task_id    String
  title      String
  position   Int
  is_done    Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  type       String
  message    String
  link       String?
  read       Boolean  @default(false)
  created_at DateTime @default(now())
}

model Reminder {
  id         String   @id @default(uuid())
  user_id    String
  title      String
  remind_at  DateTime
  notified   Boolean  @default(false)
  created_at DateTime @default(now())
}

